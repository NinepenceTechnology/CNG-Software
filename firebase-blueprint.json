{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Church member details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "baptismDate": { "type": "string", "format": "date" },
        "marriageDate": { "type": "string", "format": "date" },
        "group": { "type": "string" },
        "status": { "type": "string", "enum": ["ativo", "inativo", "visitante"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record (tithes, offerings, expenses)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["dizimo", "oferta", "contribuicao", "despesa"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "memberId": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pago", "pendente"] },
        "branchId": { "type": "string" }
      },
      "required": ["type", "amount", "date"]
    },
    "ChurchEvent": {
      "title": "Church Event",
      "description": "Scheduled events and meetings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["culto", "reuniao", "conferencia", "evento"] },
        "attendeesCount": { "type": "number" },
        "branchId": { "type": "string" }
      },
      "required": ["title", "date"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Church property and assets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["bom estado", "avariado", "obsoleto", "vendido"] },
        "value": { "type": "number" },
        "purchaseDate": { "type": "string", "format": "date" },
        "branchId": { "type": "string" }
      },
      "required": ["name", "status"]
    },
    "Report": {
      "title": "Report",
      "description": "Service reports and celebrational data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "branchId": { "type": "string" },
        "leader": { "type": "string" },
        "attendance": { "type": "object" },
        "finance": { "type": "object" },
        "comments": { "type": "string" },
        "uploadedFiles": { "type": "array" }
      },
      "required": ["date", "branchId"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global system and church configuration",
      "type": "object",
      "properties": {
        "churchName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "contact": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "settings/church": {
      "schema": "SystemSettings",
      "description": "Global church configuration"
    },
    "branches/{branchId}/members/{memberId}": {
      "schema": "Member",
      "description": "Members belonging to a specific assembly branch"
    },
    "branches/{branchId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial records for a specific branch"
    },
    "branches/{branchId}/events/{eventId}": {
      "schema": "ChurchEvent",
      "description": "Events for a specific branch"
    },
    "branches/{branchId}/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items for a specific branch"
    },
    "branches/{branchId}/reports/{reportId}": {
      "schema": "Report",
      "description": "Service reports for a specific branch"
    },
    "users/{userId}": {
      "schema": { 
        "type": "object", 
        "properties": { 
          "name": { "type": "string" },
          "role": { "type": "string" }, 
          "email": { "type": "string" },
          "group": { "type": "string" },
          "password": { "type": "string" },
          "onboardingComplete": { "type": "boolean" },
          "massPubEmail": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        } 
      },
      "description": "User profiles and permissions"
    }
  }
}
